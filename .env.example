# Copy this file to .env and fill in real values. Do NOT commit .env.
#
# Cookies for the GEM project database. Extract from your browser session:
# 1. Log into https://gem-project-db.herokuapp.com
# 2. Open DevTools → Application → Cookies
# 3. Copy sessionid and csrftoken values
# These expire periodically; re-extract when scripts start returning 302 redirects.
GEM_PROJECT_DB_SESSIONID=
GEM_PROJECT_DB_CSRFTOKEN=

# Optional. Path to the LNG Carrier Tracker project's vessels CSV export.
# Enables fsru_sync_check.py to cross-check FSRU vessel records between trackers.
# If unset, fsru_sync_check.py short-circuits to gem-only mode.
CARRIER_VESSELS_CSV_PATH=
